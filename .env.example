NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production multi-tenant hosts (required on GO54)
# Local:  APEX_HOST=localhost  ADMIN_HOST=admin.localhost  (+ hosts file for admin.localhost)
# Prod:   APEX_HOST=xonindustrialmachineries.com
#         ADMIN_HOST=admin.xonindustrialmachineries.com
APEX_HOST=localhost
ADMIN_HOST=admin.localhost

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=xon

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AUTH_SECRET=change-me-to-a-long-random-string

# 6-digit codes (set in .env.local only — never commit real values)
ADMIN_SETUP_OTP=000000
ADMIN_LOGIN_OTP=000000

WHATSAPP_NUMBER=2347053236255
CONTACT_PHONE=+2347053236255
CONTACT_EMAIL=Xonindust123@gmail.com
CONTACT_LOCATION=Lagos, Nigeria
# Optional: override Aswani Market embed (default is set in src/lib/site/contact.ts)
# CONTACT_MAP_EMBED_URL=
# EmailJS — contact form (https://www.emailjs.com/)
# Template variables: title, name, email, message, time (phone is appended to message)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Optional social links (omit to hide — no empty "Find us" block on site)
# CONTACT_FACEBOOK_URL=
# CONTACT_LINKEDIN_URL=
# CONTACT_INSTAGRAM_URL=
# CONTACT_YOUTUBE_URL=
