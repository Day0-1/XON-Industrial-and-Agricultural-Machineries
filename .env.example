# Public site URL — required for canonical URLs, sitemap, and Open Graph.
# For standalone deploy: set to https://yourdomain.com BEFORE `npm run build` (baked into the bundle).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — @handle for Twitter/X cards (e.g. XonMachineries or @xonmachineries)
# NEXT_PUBLIC_TWITTER_HANDLE=

# Production multi-tenant hosts (required on GO54)
APEX_HOST=localhost
ADMIN_HOST=admin.localhost

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=xon

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AUTH_SECRET=change-me-to-a-long-random-string

# First-time admin setup only (6-digit code in .env — not used for login)
ADMIN_SETUP_OTP=000000

WHATSAPP_NUMBER=2347053236255
CONTACT_PHONE=+2347053236255
CONTACT_PHONE_2=+2349066028889
CONTACT_EMAIL=Xonindust123@gmail.com
CONTACT_LOCATION=Lagos, Nigeria
CONTACT_YOUTUBE_URL=
CONTACT_TIKTOK_URL=

# --- EmailJS: shared service + public key ---
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_84oc1io

# Contact form ONLY (customer site) — vars: title, name, email, message, time
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_6tkw5wx

# Admin login OTP ONLY — separate template
# Template vars: passcode, time; To Email field: {{to_email}} (or {{email}})
ADMIN_OTP_EMAIL=
EMAILJS_OTP_TEMPLATE_ID=
# Optional: EmailJS private key for server-side OTP send
EMAILJS_PRIVATE_KEY=
